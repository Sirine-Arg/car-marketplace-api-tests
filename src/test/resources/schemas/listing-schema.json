{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "required": [
    "listingId",
    "status",
    "createdAt",
    "sellerId",
    "vehicle",
    "price"
  ],
  "properties": {
    "listingId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["ACTIVE", "INACTIVE", "SOLD", "DRAFT"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "sellerId": {
      "type": "string"
    },
    "vehicle": {
      "type": "object",
      "required": [
        "vin",
        "brand",
        "model",
        "year",
        "mileage",
        "fuelType",
        "transmission"
      ],
      "properties": {
        "vin": {
          "type": "string",
          "minLength": 11
        },
        "brand": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "year": {
          "type": "integer",
          "minimum": 1886
        },
        "mileage": {
          "type": "integer",
          "minimum": 0
        },
        "fuelType": {
          "type": "string",
          "enum": ["DIESEL", "PETROL", "ELECTRIC", "HYBRID"]
        },
        "transmission": {
          "type": "string",
          "enum": ["MANUAL", "AUTOMATIC"]
        }
      }
    },
    "price": {
      "type": "object",
      "required": ["amount", "currency"],
      "properties": {
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        }
      }
    }
  }
}